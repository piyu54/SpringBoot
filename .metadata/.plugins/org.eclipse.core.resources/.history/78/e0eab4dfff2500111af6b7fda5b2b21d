package com.day2;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class MyController {

	@GetMapping("/java")
	public String firstApi()
	{
		return "java is an prog lang";
	}
	
	@PostMapping("/html")
	public String secondApi()
	{
		return "html is an hypertext markup lang";
	}
	
	@PutMapping("/python")//update
	public String thirdApi()
	{
		return "python is an easy lang ";
	}
	
	@DeleteMapping("/css")
	public String fourthApi()
	{
		return "this is an fourth API";
	}
}
